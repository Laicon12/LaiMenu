local function ToggleAntiFling() 
    S.isAntiFling = not S.isAntiFling
    setBtn(UI.antiFlingBtn, S.isAntiFling)
    if S.isAntiFling then 
        track("antiFling", RunService.Stepped:Connect(function() 
            pcall(function() 
                local hrp = player.Character.HumanoidRootPart
                if hrp.AssemblyLinearVelocity.Magnitude > 250 or hrp.AssemblyAngularVelocity.Magnitude > 50 then 
                    hrp.AssemblyLinearVelocity = Vector3.zero
                    hrp.AssemblyAngularVelocity = Vector3.zero 
                end 
            end)
            for _, p in ipairs(Players:GetPlayers()) do 
                if p ~= player and p.Character then 
                    for _, pt in ipairs(p.Character:GetDescendants()) do 
