        for _,p in ipairs(Players:GetPlayers()) do addESP(p) end
        espAddedConn = track("espAdd", Players.PlayerAdded:Connect(function(p) 
            espCharConns[p] = p.CharacterAdded:Connect(function() task.wait(0.1); addESP(p) end)
            addESP(p) 
        end))
        espRemovedConn = track("espRem", Players.PlayerRemoving:Connect(removeESP))
        for _,p in ipairs(Players:GetPlayers()) do 
            if p ~= player then 
                espCharConns[p] = p.CharacterAdded:Connect(function() task.wait(0.1); addESP(p) end) 
            end 
        end 
    else 
        espFolder:ClearAllChildren()
        untrack("espAdd")
        untrack("espRem")
        for _,c in pairs(espCharConns) do c:Disconnect() end
        espCharConns = {} 
    end 
end

