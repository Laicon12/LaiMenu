local function mkPresets(parent, label, vals, box, order)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(0.92, 0, 0, 22)
    row.BackgroundTransparency = 1
    row.LayoutOrder = order
    
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(0.28, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextColor3 = T.TextDim
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 10
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    
    local w = 0.72 / #vals
    for i, v in ipairs(vals) do
        local btn = Instance.new("TextButton", row)
        btn.Size = UDim2.new(w, -3, 1, 0)
        btn.Position = UDim2.new(0.28 + w*(i-1), 2, 0, 0)
        btn.BackgroundColor3 = T.ElemBG
        btn.TextColor3 = T.TextSub
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 10
        btn.Text = tostring(v)
        btn.BorderSizePixel = 0
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
        stroke(btn)
        
        btn.MouseButton1Click:Connect(function() 
            box.Text = tostring(v)
            btn.TextColor3 = T.AccentON
            task.delay(0.3, function() btn.TextColor3 = T.TextSub end) 
        end)
    end
end

