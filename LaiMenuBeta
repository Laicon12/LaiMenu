local function stpW() 
    if wThrd then task.cancel(wThrd); wThrd = nil end
    if curW then 
        pcall(function() curW.p:Destroy() end)
        for pt, pr in pairs(curW.op) do 
            pcall(function() 
                pt.CollisionGroup = pr.g
                pt.CanCollide = pr.c 
            end) 
        end
        pcall(function() 
            player.Character.Humanoid.RequiresNeck = true
            if curW.at then curW.at:Stop() end 
        end)
        curW = nil 
    end
    workspace.FallenPartsDestroyHeight = FPDH
    for _,b in ipairs({UI.weldBangBtn, UI.weldStandBtn, UI.weldAttackBtn, UI.weldHeadBtn, UI.weldBackBtn, UI.weldCarpetBtn, UI.weldBehindBtn}) do 
