local nocParts = {}
local function ToggleNoclip() 
    S.isNoclip = not S.isNoclip
    setBtn(UI.noclipBtn, S.isNoclip)
    if S.isNoclip then 
        nocParts = {}
        pcall(function() 
            for _,p in ipairs(player.Character:GetDescendants()) do 
                if p:IsA("BasePart") then nocParts[#nocParts+1] = p end 
            end 
        end)
        noclipConn = track("noclip", RunService.Stepped:Connect(function() 
            for _,p in ipairs(nocParts) do if p and p.Parent then p.CanCollide = false end end 
        end)) 
    else 
        untrack("noclip")
        task.spawn(function() 
            local h = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if not h then 
                for _,p in ipairs(nocParts) do if p and p.Parent then p.CanCollide = true end end
                nocParts = {}
                return 
            end
            local timeout = tick() + 2
            repeat 
                task.wait(0.05)
                local touching = h:GetTouchingParts()
                local worldTouch = false
                for _,tp in ipairs(touching) do 
                    if not tp:IsDescendantOf(player.Character) then worldTouch = true; break end 
                end
                if not worldTouch then break end 
            until tick() > timeout
            task.defer(function() 
                for _,p in ipairs(nocParts) do if p and p.Parent then p.CanCollide = true end end
                nocParts = {} 
            end) 
        end) 
    end 
end

