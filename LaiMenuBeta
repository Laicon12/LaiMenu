local function StopFly() 
    if flyConn then flyConn:Disconnect(); flyConn = nil end; if flyAttach and flyAttach.Parent then flyAttach:Destroy() end; flyAttach, flyLV = nil, nil
    local char = player.Character; if char then for _,p in ipairs(char:GetDescendants()) do if p:IsA("BasePart") then pcall(function() p.CollisionGroup = "Default" end) end end end
    local hum = player.Character and player.Character:FindFirstChild("Humanoid"); if hum then pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end) end 
