-- [FIX BYPASS AC THÔNG MINH - CẢNH BÁO VÀ ÉP BẬT]
local oldIndex
local bypassWarningGiven = false

local function ToggleBypassAC() 
    -- NẾU CÓ ADONIS, CHƯA BẬT BYPASS VÀ CHƯA CẢNH BÁO -> HIỆN CẢNH BÁO 3 GIÂY
    if AdonisFound and not S.isBypassAC and not bypassWarningGiven then
        bypassWarningGiven = true
        UI.bypassAcBtn.Text = "⚠️ CÓ ADONIS! Bấm lại để CỐ BẬT"
        UI.bypassAcBtn.BackgroundColor3 = T.Warn
        UI.bypassAcBtn.TextColor3 = Color3.fromRGB(20, 20, 20)
        
        task.delay(3, function()
            if not S.isBypassAC then -- Nếu sau 3s chưa cố bấm bật thì reset lại nút
                bypassWarningGiven = false
                UI.bypassAcBtn.Text = "🪝 Bypass Walk/Jump AC"
                UI.bypassAcBtn.BackgroundColor3 = T.ElemBG
                UI.bypassAcBtn.TextColor3 = T.TextMain
            end
        end)
        return
    end

    -- Check Executor có hỗ trợ hook không
    if not hookmetamethod then 
        UI.bypassAcBtn.Text = "❌ Executor Not Supported"
        task.wait(2)
        UI.bypassAcBtn.Text = "🪝 Bypass Walk/Jump AC"
        return 
    end
    
    -- THỰC THI BẬT/TẮT (NẾU ĐÃ QUA CẢNH BÁO HOẶC KHÔNG CÓ ADONIS)
    S.isBypassAC = not S.isBypassAC
    
    if S.isBypassAC then
        -- Khi bật lên
        if AdonisFound then
            UI.bypassAcBtn.Text = "☠️ Đang ép Bypass (Nguy hiểm)"
            UI.bypassAcBtn.BackgroundColor3 = T.Troll -- Đổi sang màu đỏ cảnh báo
            UI.bypassAcBtn.TextColor3 = Color3.fromRGB(20, 20, 20)
        else
            setBtn(UI.bypassAcBtn, true) -- Bật bình thường (Xanh dương)
            UI.bypassAcBtn.Text = "🪝 Bypass Walk/Jump AC: ON"
        end
        
        -- Ép Hook Metamethod
        if not oldIndex then 
            oldIndex = hookmetamethod(game, "__index", newcclosure(function(t, k) 
                if not checkcaller() and S.isBypassAC and t:IsA("Humanoid") then 
                    if k == "WalkSpeed" then return 16 end
                    if k == "JumpPower" then return 50 end 
                end
                return oldIndex(t, k) 
            end)) 
        end 
    else
        -- Khi tắt đi
        bypassWarningGiven = false
        setBtn(UI.bypassAcBtn, false)
        UI.bypassAcBtn.Text = "🪝 Bypass Walk/Jump AC"
    end
end
UI.bypassAcBtn.MouseButton1Click:Connect(ToggleBypassAC)

