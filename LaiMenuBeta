local function ToggleFly() 
    local hrp, hum = player.Character and player.Character:FindFirstChild("HumanoidRootPart"), player.Character and player.Character:FindFirstChild("Humanoid")
    if not hrp or not hum then return end
    S.isFlying = not S.isFlying; setBtn(UI.flyBtn, S.isFlying)
    if not S.isFlying then StopFly(); return end
    hum:ChangeState(Enum.HumanoidStateType.Physics); flyAttach = Instance.new("Attachment"); flyAttach.Name, flyAttach.Parent = randName(6), hrp
    flyLV = Instance.new("LinearVelocity"); flyLV.Name, flyLV.Attachment0, flyLV.MaxForce, flyLV.VectorVelocity, flyLV.RelativeTo, flyLV.Parent = randName(6), flyAttach, 9e5, Vector3.zero, Enum.ActuatorRelativeTo.World, flyAttach
    local smooth = Vector3.zero
    flyConn = track("fly", RunService.RenderStepped:Connect(function(dt) pcall(function() 
        local h2, hm2 = player.Character and player.Character:FindFirstChild("HumanoidRootPart"), player.Character and player.Character:FindFirstChild("Humanoid")
        if not h2 or not hm2 or not flyAttach or not flyAttach.Parent then StopFly(); S.isFlying = false; setBtn(UI.flyBtn, false); return end
        hm2:ChangeState(Enum.HumanoidStateType.Physics); local dir = Vector3.zero
        if S.curFlyMode == "Camera" then 
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += camera.CFrame.LookVector end; if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= camera.CFrame.RightVector end; if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += camera.CFrame.RightVector end 
        else 
            local fwd, rgt = Vector3.new(camera.CFrame.LookVector.X, 0, camera.CFrame.LookVector.Z), Vector3.new(camera.CFrame.RightVector.X,0, camera.CFrame.RightVector.Z)
            fwd, rgt = fwd.Magnitude > 0.01 and fwd.Unit or Vector3.zero, rgt.Magnitude > 0.01 and rgt.Unit or Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += fwd end; if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= fwd end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= rgt end; if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += rgt end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.yAxis end; if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= Vector3.yAxis end 
        end
        smooth = smooth:Lerp(dir.Magnitude > 0 and dir.Unit * (tonumber(UI.flySpeedBox.Text) or 50) or Vector3.zero, math.min(1, dt*10))
        flyLV.VectorVelocity = smooth
        local flat = Vector3.new(camera.CFrame.LookVector.X, 0, camera.CFrame.LookVector.Z)
        if flat.Magnitude > 0.01 then h2.CFrame = CFrame.new(h2.Position, h2.Position + flat) end 
    end) end)) 
end

