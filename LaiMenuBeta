local oldIndex
local function ToggleBypassAC()
    if not hookmetamethod then 
        UI.bypassAcBtn.Text = "❌ Executor Not Supported"
        task.wait(2)
        UI.bypassAcBtn.Text = "🪝 Bypass Walk/Jump AC"
        return 
    end
    S.isBypassAC = not S.isBypassAC
    setBtn(UI.bypassAcBtn, S.isBypassAC)
    if S.isBypassAC and not oldIndex then
        -- [NÂNG CẤP BẢO MẬT]: Bọc newcclosure() để ngụy trang thành hàm C
        oldIndex = hookmetamethod(game, "__index", newcclosure(function(t, k)
            if not checkcaller() and S.isBypassAC and t:IsA("Humanoid") then 
                if k == "WalkSpeed" then return 16 end
                if k == "JumpPower" then return 50 end 
            end
            return oldIndex(t, k)
        end))
    end
end
